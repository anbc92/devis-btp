# =====================================================================
# Modele de configuration - COPIER en `.env` puis adapter les valeurs.
# Ne jamais commiter le vrai `.env` (il est dans .gitignore).
#
#   cp .env.example .env
#
# Generer une cle secrete forte :
#   python -c "import secrets; print(secrets.token_hex(32))"
# =====================================================================

# --- Securite (OBLIGATOIRE en production) --------------------------------
# Cle de signature des sessions. Si absente, une cle ephemere est generee
# au demarrage et les sessions ne survivent pas a un redemarrage.
SECRET_KEY=changez-moi-avec-une-cle-aleatoire-de-64-caracteres

# Cle de chiffrement des secrets stockes en base (mot de passe SMTP).
# A defaut, SECRET_KEY est utilisee. La definir separement permet de faire
# tourner SECRET_KEY sans avoir a re-saisir les mots de passe SMTP.
# ENCRYPTION_KEY=une-autre-cle-aleatoire

# Cookies de session uniquement via HTTPS. METTRE 1 EN PRODUCTION.
# Laisser vide/0 en local (HTTP) sinon la connexion ne fonctionne pas.
SESSION_COOKIE_SECURE=0

# --- Serveur -------------------------------------------------------------
# Hote et port d'ecoute (sert surtout pour `python app.py`).
HOST=127.0.0.1
PORT=5000
# Mode debug Flask : NE JAMAIS mettre 1 en production.
FLASK_DEBUG=0

# --- Base de donnees -----------------------------------------------------
# Chemin du fichier SQLite. Par defaut : devis.db a la racine du projet.
# DB_PATH=/var/lib/devis-btp/devis.db

# Racine des fichiers media (logos uploades). Par defaut : dossier static/.
# Sur un volume persistant, la pointer sur le volume pour conserver les logos.
# MEDIA_ROOT=/app/data

# --- Envoi d'emails (SMTP, optionnel) ------------------------------------
# Renseigner pour activer l'envoi des devis par email.
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# Adresse d'expedition (par defaut : MAIL_USERNAME).
MAIL_FROM=
